<div class="tasks-container">
  <div class="tasks-header">
    <h2>My Tasks</h2>
    <a href="/tasks/create" class="btn btn-primary">+ New Task</a>
  </div>

  <div class="filter-sort">
    <div class="filter-group">
      <label>Filter:</label>
      <a href="/tasks?filter=all&sort=<%= sort %>" class="filter-link <%= filter === 'all' ? 'active' : '' %>">All</a>
      <a href="/tasks?filter=pending&sort=<%= sort %>" class="filter-link <%= filter === 'pending' ? 'active' : '' %>">Pending</a>
      <a href="/tasks?filter=completed&sort=<%= sort %>" class="filter-link <%= filter === 'completed' ? 'active' : '' %>">Completed</a>
    </div>

    <div class="sort-group">
      <label>Sort:</label>
      <select onchange="window.location.href = '/tasks?filter=<%= filter %>&sort=' + this.value">
        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Newest First</option>
        <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
        <option value="alphabetical" <%= sort === 'alphabetical' ? 'selected' : '' %>>Alphabetical</option>
      </select>
    </div>
  </div>

  <% if (tasks.length === 0) { %>
    <div class="no-tasks">
      <p>No tasks found. <a href="/tasks/create">Create one now!</a></p>
    </div>
  <% } else { %>
    <div class="tasks-list">
      <% tasks.forEach(task => { %>
        <div class="task-item <%= task.status %>">
          <div class="task-content">
            <div class="task-title-section">
              <h3 class="task-title">
                <% if (task.status === 'completed') { %>
                  ✓ <%= task.title %>
                <% } else if (task.status === 'pending') { %>
                  ○ <%= task.title %>
                <% } else { %>
                  ✗ <%= task.title %>
                <% } %>
              </h3>
              <span class="task-status <%= task.status %>"><%= task.status %></span>
            </div>
            <% if (task.description) { %>
              <p class="task-description"><%= task.description %></p>
            <% } %>
            <small class="task-date">Created: <%= new Date(task.createdAt).toLocaleString() %></small>
          </div>

          <div class="task-actions">
            <% if (task.status !== 'deleted') { %>
              <a href="/tasks/<%= task.id %>/edit" class="btn btn-small btn-edit">Edit</a>
              <% if (task.status === 'pending') { %>
                <button class="btn btn-small btn-complete" onclick="updateStatus(<%= task.id %>, 'completed')">✓ Complete</button>
              <% } %>
              <% if (task.status === 'completed') { %>
                <button class="btn btn-small btn-pending" onclick="updateStatus(<%= task.id %>, 'pending')">↺ Pending</button>
              <% } %>
            <% } %>
            <button class="btn btn-small btn-delete" onclick="deleteTask(<%= task.id %>)">🗑 Delete</button>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
function updateStatus(taskId, status) {
  fetch(`/tasks/${taskId}/status`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ status })
  })
  .then(response => {
    if (response.ok) {
      location.reload();
    } else {
      alert('Failed to update task');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    alert('Error updating task');
  });
}

function deleteTask(taskId) {
  if (confirm('Are you sure you want to delete this task?')) {
    fetch(`/tasks/${taskId}/delete`, {
      method: 'POST'
    })
    .then(response => {
      if (response.ok) {
        location.reload();
      } else {
        alert('Failed to delete task');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error deleting task');
    });
  }
}
</script>
